GARMIN_EMAIL=your_email@example.com
# Garmin Password
GARMIN_PASSWORD=your_password
GEMINI_API_KEY=your_gemini_api_key

# Google Calendar Setup (Optional)
# Place 'credentials.json' and 'token_google.json' in the project root.
# The script will sync workouts to a "Coach Gemini" calendar.

### Optional: Race Goals (Leave empty for general fitness)
# RACE_DATE=2025-05-24
# RACE_DISTANCE=Full            # e.g., Full, Half, 10k, 5k
# RACE_GOAL_TIME=3:59:59        # e.g., H:MM:SS
# RACE_TARGET_PACE=5:40         # e.g., MM:SS (Overrides goal time if set)
# MAX_HEART_RATE=197            # e.g., 197

### Optional: Planner mode
# legacy    = 기존 skeleton 기반 planner (default, 안정)
# llm_driven = 새 LLM 주도 planner + SafetyValidator 자동 보정 (dev 검증 중)
# COACH_PLANNER_MODE=legacy